<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvAdminEventTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Event Title Placeholder"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1E40AF"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvAdminEventCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textSize="14sp"
            android:textColor="#F59E0B"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvAdminEventDateTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date - Time"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvAdminEventLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvAdminEventCapacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Capacity: 100"
            android:textSize="14sp"
            android:textStyle="italic"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvAdminEventStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: ACTIVE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#2563EB"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnEditAdminEvent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Edit"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2563EB" />

            <Button
                android:id="@+id/btnCancelAdminEvent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cancel"
                android:textColor="#FFFFFF"
                android:backgroundTint="#DC2626" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
